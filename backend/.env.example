# Club Management System - Environment Variables Template
# Copy this file to .env and fill in with actual values

# Database Configuration
# For local development: mongodb://localhost:27017/club-management
# For production: Use MongoDB Atlas or managed MongoDB service
MONGODB_URI=mongodb://localhost:27017/club-management

# Session Configuration
# IMPORTANT: Use a strong random string in production (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_key_here

# Environment
# Values: development | production
NODE_ENV=production

# Server Port
# Default: 5000
PORT=5000

# CORS Configuration
# Frontend URL that can make requests to this server
CORS_ORIGIN=http://localhost:3000

# Proxy Settings (if behind reverse proxy like nginx)
BEHIND_PROXY=true
